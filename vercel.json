{
  "version": 2,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    }
  ],
  "rewrites": [
    { "source": "/analyze/", "destination": "api/index.py" },
    { "source": "/report/(.*)", "destination": "api/index.py" },
    { "source": "/history/", "destination": "api/index.py" },
    { "source": "/api/(.*)", "destination": "api/index.py" },
    { "source": "/(.*)", "destination": "/frontend/$1" }
  ]
}
